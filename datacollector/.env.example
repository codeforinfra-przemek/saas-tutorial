# Copy only when datacollector/.env does not exist. Never commit the real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=medium
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_MAX_OUTPUT_TOKENS=8000
# Searcher discovery defaults. Set the domain list to an empty value to disable it.
OPENAI_WEB_SEARCH_CONTEXT_SIZE=low
OPENAI_WEB_SEARCH_BLOCKED_DOMAINS=arxiv.org,quora.com,reddit.com,wikipedia.org
