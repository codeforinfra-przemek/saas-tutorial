DJANGO_SECRET_KEY=change-me
DJANGO_ENVIRONMENT=development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Production: use a long random secret, set DJANGO_ENVIRONMENT=production and
# keep the secure defaults below. Railway/your proxy must set X-Forwarded-Proto.
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True

# Optional. Leave unset or commented out to use local db.sqlite3.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require
DB_CONN_MAX_AGE=30
DB_CONN_HEALTH_CHECKS=True
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://*.railway.app,https://*.up.railway.app

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-google-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=your-gmail-address@gmail.com
SERVER_EMAIL=your-gmail-address@gmail.com
CLAIMS_NOTIFICATION_EMAIL=claims@example.com

# GitHub OAuth App credentials. Do not use a GitHub App installation ID here.
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
ADMIN_USER_NAME=SaaS Home Admin
ADMIN_USER_EMAIL=your-gmail-address@gmail.com

# Stripe test-mode credentials. Use live keys only in the production environment.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_SUCCESS_URL=http://127.0.0.1:8000/billing/success/?session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=http://127.0.0.1:8000/pricing/vendor/

# Optional password used by the local seed_billing_demo command.
DEMO_USER_PASSWORD=DemoTest123!
